{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/server.ts",
    "src/types/**/*.d.ts"
  ],
  "project": ["src/**/*.ts"],
  "ignore": [
    "src/data-contracts/**"
  ],
  "ignoreDependencies": [
    "cors",
    "swagger-typescript-api",
    "tsconfig-paths",
    "@types/express-serve-static-core"
  ],
  "ignoreBinaries": [
    "pm2"
  ]
}
