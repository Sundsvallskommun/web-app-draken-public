{
  "compilerOptions": {
    "types": ["@simonsmith/cypress-image-snapshot/types"],
    "target": "es6",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": false,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["src/pages/*"],
      "@public/*": ["src/public/*"],
      "@config/*": ["src/config/*"],
      "@contexts/*": ["src/common/contexts/*"],
      "@supportmanagement/*": ["src/supportmanagement/*"],
      "@casedata/*": ["src/casedata/*"],
      "@common/*": ["src/common/*"],
      "@jestRoot/*": [".jest/*"],
      "@styles/*": ["src/styles/*"],
      "@cypress/*": ["cypress/*"]
      // "@services/*": ["src/services/*"],
      // "@common/components/*": ["src/components/*"],
      // "@interfaces/*": ["src/interfaces/*"],
      // "@utils/*": ["src/utils/*"],
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "src/**/*.{ts,tsx}",
    "cypress/**/*.{ts,tsx}",
    "next-env.d.ts",
    "node_modules/dayjs/plugin/utc.d.ts",
    "src/common/components/localization-provider",
    ".next-IK/types/**/*.ts",
    ".next-KA/types/**/*.ts",
    ".next-KC/types/**/*.ts",
    ".next-LOP/types/**/*.ts",
    ".next-MEX/types/**/*.ts",
    ".next-MSVA/types/**/*.ts",
    ".next-PT/types/**/*.ts",
    ".next-ROB/types/**/*.ts",
    ".next-IAF/types/**/*.ts",
    ".next/types/**/*.ts",
    ".next-SE/types/**/*.ts",
    ".next-IK/dev/types/**/*.ts",
    ".next-KA/dev/types/**/*.ts",
    ".next-KC/dev/types/**/*.ts",
    ".next-LOP/dev/types/**/*.ts",
    ".next-MEX/dev/types/**/*.ts",
    ".next-MSVA/dev/types/**/*.ts",
    ".next-PT/dev/types/**/*.ts",
    ".next-ROB/dev/types/**/*.ts",
    ".next-IAF/dev/types/**/*.ts",
    ".next-SE/dev/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
