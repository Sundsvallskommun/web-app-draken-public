{
  "compilerOptions": {
    "types": ["@simonsmith/cypress-image-snapshot/types", "vite/client"],
    "target": "es6",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["src/pages/*"],
      "@public/*": ["src/public/*"],
      "@config/*": ["src/config/*"],
      "@contexts/*": ["src/common/contexts/*"],
      "@supportmanagement/*": ["src/supportmanagement/*"],
      "@casedata/*": ["src/casedata/*"],
      "@common/*": ["src/common/*"],
      "@jestRoot/*": [".jest/*"],
      "@styles/*": ["src/styles/*"],
      "@cypress/*": ["cypress/*"],
      "@stores/*": ["src/stores/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "cypress/**/*.ts",
    "cypress/**/*.tsx",
    "node_modules/dayjs/plugin/utc.d.ts"
  ],
  "exclude": ["node_modules"]
}
